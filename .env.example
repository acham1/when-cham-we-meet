# Firebase client configuration.
# In production, these are fetched from GCP Secret Manager at build time (see deploy.sh).
# For local development, copy this to .env and fill in your Firebase web-app config.
#
# To create the secret:
#   gcloud secrets create when2meet-env --project=YOUR_PROJECT
#   gcloud secrets versions add when2meet-env --data-file=.env --project=YOUR_PROJECT

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
